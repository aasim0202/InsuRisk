# ── LLM smart switch ──────────────────────────────────────────
# auto = try local Ollama first, fall back to Ollama Cloud if local is unreachable.
# Options: auto | local | cloud
LLM_MODE=auto

# Local Ollama (tried first in auto mode)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Ollama Cloud fallback (used when local is down, or in cloud mode)
#   - get a key at https://ollama.com/settings/keys
#   - pick a cloud model from https://ollama.com/search?c=cloud
OLLAMA_CLOUD_URL=https://ollama.com
OLLAMA_CLOUD_MODEL=gpt-oss:120b
OLLAMA_API_KEY=

# ── Web enrichment ──
TAVILY_API_KEY=tvly-your-key-here

# ── Output storage (optional) ─────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=insurisk-outputs
