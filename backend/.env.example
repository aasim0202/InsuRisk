# ── LLM provider ──────────────────────────────────────────────
# LOCAL Ollama (default):
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_API_KEY=

# OLLAMA CLOUD (use this if local Ollama is blocked, e.g. by endpoint security):
#   OLLAMA_URL=https://ollama.com
#   OLLAMA_MODEL=gpt-oss:120b          # pick a cloud model from https://ollama.com/search?c=cloud
#   OLLAMA_API_KEY=your-ollama-cloud-key   # from https://ollama.com/settings/keys

# ── Web enrichment ────────────────────────────────────────────
TAVILY_API_KEY=tvly-your-key-here

# ── Output storage (optional) ─────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=insurisk-outputs
